{
  "name": "noaa-marine-mcp-server",
  "version": "0.3.0",
  "description": "Find NOAA tide stations and NDBC buoys, fetch tide predictions, water levels, tidal currents, and live buoy conditions via MCP. STDIO or Streamable HTTP.",
  "author": {
    "name": "cyanheads"
  },
  "homepage": "https://github.com/cyanheads/noaa-marine-mcp-server#readme",
  "repository": "git+https://github.com/cyanheads/noaa-marine-mcp-server.git",
  "license": "Apache-2.0",
  "mcpServers": {
    "noaa-marine-mcp-server": {
      "command": "npx",
      "args": [
        "-y",
        "@cyanheads/noaa-marine-mcp-server"
      ],
      "env": {
        "MCP_TRANSPORT_TYPE": "stdio"
      }
    }
  }
}
